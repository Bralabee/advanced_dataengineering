# Example environment file for local development
# Copy to .env and fill in your real values

# Azure credentials (used by Fabric, Azurite, etc.)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name

# Azurite local development (for local blob storage emulation)
AZURITE_BLOB_ENDPOINT=http://azurite:10000/devstoreaccount1
AZURITE_ACCOUNT_NAME=devstoreaccount1
